<Window x:Class="PasswordManager.Views.NewFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PasswordManager.Views"
        mc:Ignorable="d"
        Style="{DynamicResource DialogWindowStyle}"
        Title="Create new folder">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Folder name:" Grid.Column="0" Style="{DynamicResource DialogTextBlockStyle}"/>
            <TextBox x:Name="FolderNameTextBox" Grid.Column="1" Style="{DynamicResource DialogTextBoxStyle}"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0 20 0 0">
            
            <Button x:Name="ConfirmBtn" Content="Add" Style="{DynamicResource DialogButtonOK}" 
                    Click="AddButton_Click"/>

            <Button Content="Cancel" Style="{DynamicResource DialogButtonCancel}"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
