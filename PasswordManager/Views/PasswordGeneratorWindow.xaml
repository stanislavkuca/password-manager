<Window x:Class="PasswordManager.Views.PasswordGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PasswordManager.Views"
        Style="{DynamicResource DialogWindowStyle}"
        Title="PasswordGeneratorWindow"
        Height="350" Width="300"
        MaxWidth="400" MinWidth="300"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="ResultTextBox" Grid.Row="0" FontSize="20" FontWeight="Bold"
                 TextAlignment="Center" Padding="10" IsReadOnly="True"
                 Style="{DynamicResource DialogTextBoxStyle}" Width="Auto" Margin="0 0 0 20"/>

        <StackPanel Grid.Row="1" Margin="0 0 0 20">
            <DockPanel Margin="0 0 0 10">
                <TextBlock Text="Length:" Foreground="{DynamicResource TextBrush}" 
                           FontSize="16" DockPanel.Dock="Left"/>
                <TextBlock x:Name="LengthText" Text="16" Foreground="{DynamicResource PrimaryAccentBrush}" 
                           FontSize="16" FontWeight="Bold" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            </DockPanel>

            <Slider x:Name="LengthSlider" Minimum="8" Maximum="64" Value="16"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    ValueChanged="LengthSlider_ValueChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <CheckBox x:Name="CbUppercase" Content="Uppercase (A-Z)" IsChecked="True" 
                      Margin="0 5" Foreground="{DynamicResource TextBrush}" FontSize="14" 
                      Checked="Option_Changed" Unchecked="Option_Changed"/>
            <CheckBox x:Name="CbLowercase" Content="Lowercase (a-z)" IsChecked="True" 
                      Margin="0 5" Foreground="{DynamicResource TextBrush}" FontSize="14" 
                      Checked="Option_Changed" Unchecked="Option_Changed"/>
            <CheckBox x:Name="CbNumbers" Content="Numbers (0-9)" IsChecked="True" 
                      Margin="0 5" Foreground="{DynamicResource TextBrush}" FontSize="14" 
                      Checked="Option_Changed" Unchecked="Option_Changed"/>
            <CheckBox x:Name="CbSpecial" Content="Special characters (!@#...)" IsChecked="True" 
                      Margin="0 5" Foreground="{DynamicResource TextBrush}" FontSize="14" 
                      Checked="Option_Changed" Unchecked="Option_Changed"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Button Content="Generate" Click="Generate_Click" Margin="0 0 10 0" Padding="15 8" Cursor="Hand"/>
            <Button Content="Use Password" Click="UsePassword_Click" Style="{DynamicResource DialogButtonOK}" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
