<Window x:Class="PasswordManager.Views.DeleteAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PasswordManager.Views"
        mc:Ignorable="d"
        Style="{DynamicResource DialogWindowStyle}"
        Title="Confirm deletion">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0 15 0 0">

            <Button Click="DeleteAccountButton_Click" 
                    Content="Delete" Style="{DynamicResource DeleteConfirmationButtonStyle}" Margin="0 0 20 0"/>

            <Button IsCancel="True" 
                    Content="Cancel" Style="{DynamicResource DialogButtonCancel}"/>
        </StackPanel>
    </Grid>
</Window>
