<Window x:Class="PasswordManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:PasswordManager.Models"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance IsDesignTimeCreatable=True}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Title="Password Manager Alpha"
        Width="1400" Height="700"
        MinWidth="1000" MinHeight="500">

    <Grid Background="{DynamicResource PrimaryGradient}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock FontSize="23" Margin="20" HorizontalAlignment="Center">
                    <Run Text="Pass" FontWeight="Bold"/>
                    <Run Text="Manager" FontWeight="Light"/>
                </TextBlock>

                <Button Style="{DynamicResource MainMenuButtonStyle}" Click="AllPasswordsButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{DynamicResource PasswordsIcon}" Width="24" Height="24" Margin="10 0 15 0"/>
                        <TextBlock Text="All Accounts" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- SETTINGS BUTTON AT BOTTOM 
            <Button Style="{DynamicResource MainMenuButtonStyle}" VerticalAlignment="Bottom"
                    DockPanel.Dock="Bottom" Margin="5">
                
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource SettingsIcon}" Width="24" Height="24" Margin="10 0 15 0"/>
                    <TextBlock Text="Settings" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            -->
            <CheckBox x:Name="ThemeToggleButton"
                      Style="{DynamicResource ThemeToggleSwitch}"
                      Content="Dark Theme"
                      DockPanel.Dock="Bottom"
                      Margin="20 10"
                      VerticalAlignment="Bottom"
                      Checked="ThemeToggleButton_Checked"
                      Unchecked="ThemeToggleButton_Unchecked"/>

            <StackPanel>
                <Label Content="Folders:" Style="{DynamicResource LabelStyle}"/>

                <!--FOLDER LIST -->
                <ListBox ItemsSource="{Binding Folders}"
                        ItemContainerStyle="{DynamicResource FolderItemStyle}"
                        SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                        PreviewMouseRightButtonDown="OnPreviewMouseRightBtnDown"
                        BorderThickness="0"
                        Background="Transparent"
                        x:Name="FoldersListBox"
                        HorizontalAlignment="Stretch"
                        Margin="20 0 20 0">
                
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <!-- RENAME FOLDER -->
                                        <MenuItem Header="Rename Folder" Icon="✏️" Click="RenameFolder_Click"/>
                                        <Separator/>
                                    
                                        <!-- DELETE FOLDER -->
                                        <MenuItem Header="Delete Folder" Icon="🗑️" Click="DeleteFolder_Click" Foreground="{DynamicResource DangerBrush}"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>

                                <TextBlock Text="{Binding Name, StringFormat=• {0}}"
                                            Padding="30 6"
                                            FontSize="18"
                                            TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </DockPanel>

        <!-- RIGHT SIDE CONTENT -->
        <Grid Grid.Column="1" Margin="10 0 0 0"
              Focusable="True" Background="Transparent"
              MouseDown="Grid_MouseDown">
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP RIGHT ACTION MENU -->
            <DockPanel Grid.Row="0" Margin="0 10 10 20">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    
                    <Button Style="{DynamicResource SecondaryMenuButtonStyle}" Click="NewAccountButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource NewAccountIcon}" Width="24" Height="24" Margin="0 0 10 0"/>
                            <TextBlock Text="New account" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource SecondaryMenuButtonStyle}" Click="NewFolderButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource NewFolderIcon}" Width="24" Height="24" Margin="0 0 10 0"/>
                            <TextBlock Text="New folder" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                </StackPanel>

                <!-- SEARCH BOX RIGHT -->
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource SearchBoxStyle}"
                         KeyDown="SearchBox_KeyDown"/>
            </DockPanel>

            <!-- ACCOUNT LIST -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding DisplayedAccounts}"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{DynamicResource CleanListBoxItemStyle}"
                     x:Name="AccountList">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{DynamicResource AccountBorderStyle}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Copy Username" Icon="📋" Click="CopyUsername_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Copy Password" Icon="📋" Click="CopyPassword_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Account fields -->
                                <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0 0 20 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="0" FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding Username}" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="1"/>

                                    <TextBlock Text="********" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="2"/>

                                    <TextBlock Text="{Binding Note}" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="3" Margin="0 0 40 0"/>
                                </Grid>

                                <!-- ACCOUNT BUTTONS -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <!-- FAVOURITE -->
                                    <Button Style="{DynamicResource FavouriteButtonStyle}" Click="FavouriteButton_Click" Margin="0 0 15 0"/>
                                    
                                    <!--ADD TO FOLDER -->
                                    <Button Style="{DynamicResource PlusFolderButtonStyle}" 
                                            Tag="{Binding AccountId}"
                                            Click="FolderButton_Click"
                                            Margin="0 0 10 0">
                                        <Button.ContextMenu>
                                            <ContextMenu Opened="FolderMenu_Opened"/>
                                        </Button.ContextMenu>
                                    </Button>
                                    
                                    <!-- EDIT -->
                                    <Button Content="Edit" Style="{DynamicResource EditButtonStyle}" Click="EditAccountBtn_Click" Margin="0 0 25 0"/>
                                    
                                    <!-- DELETE -->
                                    <Button Content="Delete" Style="{DynamicResource DeleteButtonStyle}" Click="DeleteAccountButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <!-- TIMER -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Security logout in:" Margin="0 0 5 0" Style="{DynamicResource TimerDisplayText}"/>
                <TextBlock x:Name="TimerDisplay" Text="05:00" FontWeight="SemiBold" Style="{DynamicResource TimerDisplayText}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
