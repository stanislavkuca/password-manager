<Window x:Class="PasswordManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:PasswordManager.Models"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=models:AccountListData, IsDesignTimeCreatable=True}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Title="Password Manager Alpha"
        Width="1400" Height="700"
        MinWidth="1000" MinHeight="500">

    <Grid Background="{DynamicResource PrimaryGradient}" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock FontSize="23"
                       FontWeight="Bold"
                       Margin="20"
                       HorizontalAlignment="Center"
                       FontFamily="{DynamicResource AudiowideFont}">
                    <Run Text="Password"/>
                    <LineBreak/>
                    <Run Text="Manager"/>
                </TextBlock>

                <Button Style="{DynamicResource MainMenuButtonStyle}" Click="AllPasswordsButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{DynamicResource PasswordsIcon}" Width="24" Height="24" Margin="10 0 15 0"/>
                        <TextBlock Text="All Accounts" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- SETTINGS BUTTON AT BOTTOM -->
            <Button Style="{DynamicResource MainMenuButtonStyle}" VerticalAlignment="Bottom"
                    DockPanel.Dock="Bottom" Margin="5">
                
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource SettingsIcon}" Width="24" Height="24" Margin="10 0 15 0"/>
                    <TextBlock Text="Settings" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!--FOLDER LIST -->
            <ListBox ItemsSource="{Binding Folders}"
                    ItemContainerStyle="{DynamicResource FolderItemStyle}"
                    SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                    PreviewMouseRightButtonDown="OnPreviewMouseRightBtnDown"
                    BorderThickness="0"
                    Background="Transparent"
                    x:Name="FoldersListBox"
                    HorizontalAlignment="Stretch"
                    Margin="20 0 20 0">
                
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Background="Transparent">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <!-- RENAME FOLDER -->
                                    <MenuItem Header="Rename Folder" Click="RenameFolder_Click" Icon="✏️"/>
                                    <Separator/>
                                    
                                    <!-- DELETE FOLDER -->
                                    <MenuItem Header="Delete Folder" Click="DeleteFolder_Click" Icon="🗑️" Foreground="{DynamicResource DangerBrush}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <TextBlock Text="{Binding Name, StringFormat=• {0}}"
                                        Padding="30 6"
                                        FontSize="18"
                                        TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- RIGHT SIDE CONTENT -->
        <Grid Grid.Column="1" Margin="10 0 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP RIGHT ACTION MENU -->
            <DockPanel Grid.Row="0" Margin="0 10 10 20">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    
                    <Button Style="{DynamicResource SecondaryMenuButtonStyle}" Click="NewAccountButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource NewAccountIcon}" Width="24" Height="24" Margin="0 0 10 0"/>
                            <TextBlock Text="New account" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource SecondaryMenuButtonStyle}" Click="NewFolderButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource NewFolderIcon}" Width="24" Height="24" Margin="0 0 10 0"/>
                            <TextBlock Text="New folder" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                </StackPanel>

                <!-- SEARCH BOX RIGHT -->
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource SearchBoxStyle}"/>
            </DockPanel>

            <!-- ACCOUNT LIST -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding DisplayedAccounts}"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{DynamicResource CleanListBoxItemStyle}"
                     x:Name="AccountList">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{DynamicResource AccountBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Account fields -->
                                <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0 0 20 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="0" FontWeight="SemiBold"/>

                                    <TextBlock Text="{Binding Username}" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="1"/>

                                    <TextBlock Text="********" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="2"/>

                                    <TextBlock Text="{Binding Note}" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="3" Margin="0 0 40 0"/>
                                </Grid>

                                <!-- Buttons -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{DynamicResource FavouriteButtonStyle}" Click="FavouriteButton_Click"/>

                                    <Button Style="{DynamicResource PlusFolderButtonStyle}" 
                                            Tag="{Binding Id}"
                                            Click="FolderButton_Click">
                                        <Button.ContextMenu>
                                            <ContextMenu Opened="FolderMenu_Opened"/>
                                        </Button.ContextMenu>
                                    </Button>
                                    
                                    <Button Content="Edit" Style="{DynamicResource EditButtonStyle}" Click="EditAccountBtn_Click"/>

                                    <Button Content="Delete" Style="{DynamicResource DeleteButtonStyle}" Click="DeleteConfirmationButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
