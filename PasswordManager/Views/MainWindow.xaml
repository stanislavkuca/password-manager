<Window x:Class="PasswordManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:PasswordManager.Models"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance IsDesignTimeCreatable=True}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Title="Password Manager Alpha"
        Width="1400" Height="700"
        MinWidth="1100" MinHeight="500"
        PreviewMouseMove="Window_UserActivity"
        PreviewKeyDown="Window_UserActivity">

    <Grid Background="{DynamicResource PrimaryGradient}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT MENU -->
        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock FontSize="23" Margin="20" HorizontalAlignment="Center">
                    <Run Text="Pass" FontWeight="Bold"/>
                    <Run Text="Manager" FontWeight="Light"/>
                </TextBlock>

                <Button Style="{DynamicResource MainMenuButtonStyle}" Click="AllPasswordsButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{DynamicResource PasswordsIcon}" Width="24" Height="24" Margin="10 0 15 0"/>
                        <TextBlock Text="All Accounts" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <CheckBox x:Name="ThemeToggleButton"
                      Style="{DynamicResource ThemeToggleSwitch}"
                      Content="Dark Theme"
                      DockPanel.Dock="Bottom"
                      Margin="20 10"
                      VerticalAlignment="Bottom"
                      Checked="ThemeToggleButton_Checked"
                      Unchecked="ThemeToggleButton_Unchecked"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Label Content="Folders:" Margin="20 0 20 0"
                       Style="{DynamicResource LabelStyle}" Grid.Row="0"/>

                <!--FOLDER LIST -->
                <ListBox Grid.Row="1"
                        ItemsSource="{Binding Folders}"
                        ItemContainerStyle="{DynamicResource FolderItemStyle}"
                        SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                        PreviewMouseRightButtonDown="OnPreviewMouseRightBtnDown"
                        BorderThickness="0"
                        Background="Transparent"
                        x:Name="FoldersListBox"
                        HorizontalAlignment="Stretch"
                        Margin="20 0 20 0" 
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Rename Folder" Icon="✏️" Click="RenameFolder_Click"/>
                                        
                                        <Separator/>
                                    
                                        <MenuItem Header="Delete Folder" Icon="🗑️" Click="DeleteFolder_Click" Foreground="{DynamicResource DangerBrush}"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Path Grid.Column="0"
                                      Width="16" Height="16"
                                      Margin="12 8 12 8"
                                      Stretch="Uniform"
                                      Fill="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                      Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </DockPanel>

        <!-- RIGHT SIDE CONTENT -->
        <Grid Grid.Column="1" Margin="10 0 10 0"
              Focusable="True" Background="Transparent"
              MouseDown="Grid_MouseDown"
              Grid.IsSharedSizeScope="True">
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP RIGHT ACTION MENU -->
            <DockPanel Grid.Row="0" Margin="0 10 10 20">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    
                    <Button Style="{DynamicResource SecondaryMenuButtonStyle}" Click="NewAccountButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource NewAccountIcon}" Width="24" Height="24" Margin="0 0 10 0"/>
                            <TextBlock Text="New account" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource SecondaryMenuButtonStyle}" Click="NewFolderButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{DynamicResource NewFolderIcon}" Width="24" Height="24" Margin="0 0 10 0"/>
                            <TextBlock Text="New folder" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                </StackPanel>

                <!-- SEARCH BOX RIGHT -->
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource SearchBoxStyle}"
                         KeyDown="SearchBox_KeyDown"/>
            </DockPanel>
            
            <!-- HEADER -->
            <Grid Grid.Row="1" Margin="15 0 20 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="ActionButtonsColumn"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.5*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Service name" Grid.Column="0" Foreground="{DynamicResource TextSecondaryBrush}" 
                               FontWeight="SemiBold" FontSize="13" Opacity="0.7"/>
                    <TextBlock Text="Username" Grid.Column="1" Foreground="{DynamicResource TextSecondaryBrush}" 
                               FontWeight="SemiBold" FontSize="13" Opacity="0.7"/>
                    <TextBlock Text="Password" Grid.Column="2" Foreground="{DynamicResource TextSecondaryBrush}" 
                               FontWeight="SemiBold" FontSize="13" Opacity="0.7"/>
                    <TextBlock Text="Note" Grid.Column="3" Foreground="{DynamicResource TextSecondaryBrush}" 
                               FontWeight="SemiBold" FontSize="13" Opacity="0.7"/>
                </Grid>
            </Grid>

            <!-- ACCOUNT LIST -->
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding DisplayedAccounts}"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     ItemContainerStyle="{DynamicResource CleanListBoxItemStyle}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     x:Name="AccountList">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{DynamicResource AccountBorderStyle}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Copy Username" Icon="📋" Click="CopyUsername_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Copy Password" Icon="📋" Click="CopyPassword_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ActionButtonsColumn"/>
                                </Grid.ColumnDefinitions>

                                <!-- Account fields -->
                                <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="0.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding MaskedUsername}" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="1" TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="********" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="2" TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding Note}" Style="{DynamicResource AccountItemTemplateStyle}"
                                               Grid.Column="3" Margin="0 0 40 0" TextTrimming="CharacterEllipsis"/>
                                </Grid>

                                <!-- ACCOUNT BUTTONS -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <!-- FAVOURITE -->
                                    <Button Style="{DynamicResource FavouriteButtonStyle}" Click="FavouriteButton_Click" Margin="0 0 15 0"/>
                                    
                                    <!--ADD TO FOLDER -->
                                    <Button Style="{DynamicResource PlusFolderButtonStyle}" 
                                            Tag="{Binding AccountId}"
                                            Click="FolderButton_Click"
                                            Margin="0 0 10 0">
                                        <Button.ContextMenu>
                                            <ContextMenu Opened="FolderMenu_Opened"/>
                                        </Button.ContextMenu>
                                    </Button>
                                    
                                    <Button Content="Edit" Style="{DynamicResource EditButtonStyle}" Click="EditAccountBtn_Click" Margin="0 0 25 0"/>
                                    
                                    <Button Content="Delete" Style="{DynamicResource DeleteButtonStyle}" Click="DeleteAccountButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <!-- TIMER -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Security logout in:" Margin="0 0 5 0" Style="{DynamicResource TimerDisplayText}"/>
                <TextBlock x:Name="TimerDisplay" Text="05:00" FontWeight="SemiBold" Style="{DynamicResource TimerDisplayText}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
