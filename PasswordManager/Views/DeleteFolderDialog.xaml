<Window x:Class="PasswordManager.Views.DeleteFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PasswordManager.Views"
        mc:Ignorable="d"
        Style="{DynamicResource DialogWindowStyle}"
        Title="Delete Folder">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Would you like to also delete the accounts?" Grid.Row="0" Style="{DynamicResource DialogTextBlockStyle}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0 15 0 0">

            <Button Click="DeleteFolderOnlyBtn_Click" 
                    Content="Delete folder only" Style="{DynamicResource DeleteConfirmationButtonStyle}" Margin="0 0 20 0"/>

            <Button Click="DeleteEverythingBtn_Click" 
                    Content="Delete everything" Style="{DynamicResource DeleteConfirmationButtonStyle}" Margin="0 0 20 0"/>

            <Button IsCancel="True"
                    Content="Cancel" Style="{DynamicResource DialogButtonCancel}"/>
        </StackPanel>
    </Grid>
</Window>
